# Cloud Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM PROVIDER SELECTION
# ============================================
# Options: ollama, openrouter, huggingface
# For cloud deployment, use: openrouter (recommended) or huggingface
LLM_PROVIDER=openrouter

# ============================================
# OPENROUTER CONFIGURATION (RECOMMENDED FOR CLOUD)
# ============================================
# Get your free API key at: https://openrouter.ai/keys
# Free models available - no credit card required!
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Free tier models (no payment required):
# - meta-llama/llama-3.2-3b-instruct:free
# - google/gemma-2-9b-it:free
# - mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ============================================
# HUGGINGFACE CONFIGURATION (ALTERNATIVE)
# ============================================
# Get token at: https://huggingface.co/settings/tokens
# HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# ============================================
# OLLAMA CONFIGURATION (FOR LOCAL ONLY)
# ============================================
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# YOUTUBE DATA API (REQUIRED)
# ============================================
# Get API key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_DATA_API_KEY=your_youtube_api_key_here

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
# Set to true for cloud deployment
USE_CLOUD_PIPELINE=true

# Server configuration
PORT=8000
HOST=0.0.0.0

# CORS origins (comma-separated)
# For Chrome extension, include: chrome-extension://*
ALLOWED_ORIGINS=*
